# ==============================================================================
# Firepit Environment Configuration
# ==============================================================================
# Copy this file to .env.local and fill in your values.
# See DEPLOYMENT.md for detailed setup instructions.
#
# Quick Start:
# 1. Create an Appwrite project: https://appwrite.io
# 2. Generate an API key with full permissions
# 3. Fill in REQUIRED variables below
# 4. Run: bun run setup
# 5. Run: bun dev
#
# IMPORTANT: For deployed environments (Vercel, Appwrite, etc.):
# These environment variables are automatically exposed at runtime through
# next.config.ts. Simply set them in your deployment platform's environment
# settings and redeploy. No NEXT_PUBLIC_ prefix needed - they remain secure
# and server-side only.
# ==============================================================================

# ==============================================================================
# REQUIRED: Appwrite Connection
# ==============================================================================
# Get these from your Appwrite Console dashboard

# Your Appwrite instance URL
# Cloud: https://nyc.cloud.appwrite.io/v1 (or eu/sgp region)
# Self-hosted: https://your-domain.com/v1
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1

# Browser SDK endpoint (mirrors server value)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1

# Your Project ID from Appwrite Console
# Find this in: Appwrite Console > [Your Project] > Settings
APPWRITE_PROJECT_ID=your-project-id-here

# Browser SDK project ID (mirrors server value)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id-here

# API Key for server-side operations and setup script
# Generate in: Appwrite Console > Settings > API Keys
# Required Scopes: databases.*, collections.*, attributes.*, indexes.*, teams.*
APPWRITE_API_KEY=your-api-key-here

# ==============================================================================
# OPTIONAL: Database & Collection IDs
# ==============================================================================
# The setup script (bun run setup) will create these automatically.
# Only change these if you want to use different names or have existing collections.
# Default values below work out of the box - no need to change!

# Main database name
APPWRITE_DATABASE_ID=main

# Core chat collections
APPWRITE_SERVERS_COLLECTION_ID=servers
APPWRITE_CHANNELS_COLLECTION_ID=channels
APPWRITE_MESSAGES_COLLECTION_ID=messages
APPWRITE_MEMBERSHIPS_COLLECTION_ID=memberships
APPWRITE_TYPING_COLLECTION_ID=typing
APPWRITE_BANNED_USERS_COLLECTION_ID=banned_users
APPWRITE_MUTED_USERS_COLLECTION_ID=muted_users

# User profiles and avatars
APPWRITE_PROFILES_COLLECTION_ID=profiles
APPWRITE_AVATARS_BUCKET_ID=avatars
APPWRITE_AVATAR_FRAMES_BUCKET_ID=avatar-frames
APPWRITE_AVATAR_FRAMES_PREDEFINED_BUCKET_ID=avatar-frames-predefined

# Custom emojis
APPWRITE_EMOJIS_BUCKET_ID=emojis

# GIF/sticker media (optional)
APPWRITE_GIFS_BUCKET_ID=gifs
APPWRITE_STICKERS_BUCKET_ID=stickers

# Direct messages and status features (optional)
APPWRITE_CONVERSATIONS_COLLECTION_ID=conversations
APPWRITE_DIRECT_MESSAGES_COLLECTION_ID=direct_messages
APPWRITE_STATUSES_COLLECTION_ID=statuses
APPWRITE_NOTIFICATION_SETTINGS_COLLECTION_ID=notification_settings
APPWRITE_THREAD_READS_COLLECTION_ID=thread_reads

# Instance announcements (optional)
APPWRITE_ANNOUNCEMENTS_COLLECTION_ID=announcements
APPWRITE_ANNOUNCEMENT_DELIVERIES_COLLECTION_ID=announcement_deliveries

# Moderation and audit (optional)
APPWRITE_AUDIT_COLLECTION_ID=audit

# ==============================================================================
# OPTIONAL: Admin & Moderator Configuration
# ==============================================================================
# Two ways to grant admin/moderator access:
# 1. USER ID BOOTSTRAP (before teams exist) - Use APPWRITE_ADMIN_USER_IDS
# 2. TEAM MEMBERSHIP (after setup script) - Use APPWRITE_ADMIN_TEAM_ID

# --- METHOD 1: User ID Bootstrap ---
# Best for: Initial setup, granting yourself admin access
# How to get your user ID:
#   1. Create account in the app
#   2. Visit: http://localhost:3000/api/me
#   3. Copy the "$id" value
#   4. Add it here (comma-separated for multiple users)
APPWRITE_ADMIN_USER_IDS=
APPWRITE_MODERATOR_USER_IDS=

# --- METHOD 2: Team-Based Access ---
# Best for: Production, managing multiple admins/moderators
# The setup script creates "Admins" and "Moderators" teams automatically.
# After running setup, add users to teams via Appwrite Console > Auth > Teams
# Then set the team IDs here (find in Appwrite Console):
APPWRITE_ADMIN_TEAM_ID=
APPWRITE_MODERATOR_TEAM_ID=

# ==============================================================================
# OPTIONAL: Server Configuration
# ==============================================================================
# Public URL of your application (for OAuth redirects, etc.)
SERVER_URL=http://localhost:3000

# System user ID used as sender for instance announcement DMs.
# Leave blank to disable announcement fanout delivery until configured.
SYSTEM_SENDER_USER_ID=

# Shared secret for announcement dispatch cron route authentication.
ANNOUNCEMENTS_DISPATCHER_SECRET=

# GIF/Sticker provider (optional)
# Active GIF provider: giphy (default) or tenor (legacy fallback).
GIF_PROVIDER=giphy
# GIPHY API key for server-side GIF search proxy.
GIPHY_API_KEY=
# GIPHY content rating (y, g, pg, pg-13, r).
GIPHY_RATING=g
# GIPHY language code (e.g. en, es, pt).
GIPHY_LANG=en
# Tenor settings (legacy fallback when GIF_PROVIDER=tenor).
TENOR_API_KEY=
TENOR_CLIENT_KEY=firepit-web
TENOR_LOCALE=en_US

# ==============================================================================
# OPTIONAL: New Relic APM (Application Performance Monitoring)
# ==============================================================================
# Configure New Relic for application monitoring and log ingestion.
# These are server-side only (no NEXT_PUBLIC prefix needed).
# Get these from your New Relic account: https://newrelic.com

# Your New Relic license key
# Find in: New Relic > Account Settings > API Keys > License Keys
NEW_RELIC_LICENSE_KEY=

# Application name as it appears in New Relic
# Example: firepit-production, firepit-staging, etc.
NEW_RELIC_APP_NAME=

# ==============================================================================
# OPTIONAL: Telemetry Provider Routing
# ==============================================================================
# Controls where server-side telemetry from src/lib/newrelic-utils.ts is sent.
# Allowed values: newrelic, posthog, both, none
# Default: newrelic
TELEMETRY_PROVIDER=newrelic

# Controls where client-side telemetry from src/lib/client-telemetry.ts is sent.
# Allowed values: newrelic, posthog, both, none
# Default: newrelic
NEXT_PUBLIC_TELEMETRY_PROVIDER=newrelic

# Enable PostHog forwarding during tests (normally disabled)
# ENABLE_POSTHOG_IN_TESTS=false

# ==============================================================================
# OPTIONAL: PostHog Analytics
# ==============================================================================
# Project API key/token and host for PostHog server-side capture.
# You can use POSTHOG_* values or the NEXT_PUBLIC_* equivalents.
# Server-side vars are preferred for backend telemetry.

POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Required for PostHog Next.js source map uploads (error tracking)
POSTHOG_PROJECT_ID=
# Personal API key with project write permissions for source map upload
POSTHOG_API_KEY=

# Existing client-side vars used by instrumentation-client.ts
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Set this to your PostHog reverse-proxy domain if you have one.
# Example: https://p.your-domain.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog privacy and bandwidth controls (recommended defaults below):
# Keep autocapture OFF to avoid capturing clicked button text/user labels.
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=false
# Keep session recording OFF unless explicitly needed.
NEXT_PUBLIC_POSTHOG_SESSION_RECORDING=false
# Keep pageview capture ON for basic traffic analytics.
NEXT_PUBLIC_POSTHOG_CAPTURE_PAGEVIEW=true
# Keep request batching ON to reduce ingestion request frequency.
NEXT_PUBLIC_POSTHOG_REQUEST_BATCHING=true

# Optional Next.js rewrite configuration for PostHog proxying.
# Keep defaults unless you need custom proxy path/targets.
# Set POSTHOG_REWRITE_ENABLED=false to disable Next.js rewrites.
POSTHOG_REWRITE_ENABLED=true
POSTHOG_REWRITE_PATH=/ingest
POSTHOG_REWRITE_INGEST_HOST=https://us.i.posthog.com
POSTHOG_REWRITE_STATIC_HOST=https://us-assets.i.posthog.com

# ==============================================================================
# DEVELOPMENT ONLY
# ==============================================================================
# Enable service worker registration in local development
# (production always registers regardless of this flag)
# NEXT_PUBLIC_ENABLE_SW_IN_DEV=true

# Skip team creation during setup (useful for testing)
# SKIP_TEAMS=false
