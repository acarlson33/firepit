{
    "name": "firepit",
    "version": "1.8.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev ",
        "dev:webpack": "next dev --webpack",
        "build": "bun run generate-version && next build",
        "build:webpack": "bun run generate-version && next build --webpack",
        "build:analyze": "ANALYZE=true next build --webpack",
        "generate-version": "bun scripts/generate-version.ts",
        "start": "next start",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint \"**/*.{ts,tsx,js,mjs,cjs}\"",
        "lint:fix": "eslint \"**/*.{ts,tsx,js,mjs,cjs}\" --fix",
        "check": "bun run lint",
        "setup": "bun scripts/setup-appwrite.ts",
        "validate-env": "bun scripts/validate-env.ts",
        "validate-env:ci": "bun scripts/validate-ci-env.ts",
        "cleanup-orphan-memberships": "bun run scripts/cleanup-orphan-memberships.ts",
        "knip": "knip"
    },
    "dependencies": {
