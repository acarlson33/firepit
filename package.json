        "lucide-react": "^0.554.0",
        "nanoid": "^5.1.11",
        "newrelic": "^13.19.2",
        "next": "^16.2.4",
        "next-themes": "^0.4.6",
        "node-appwrite": "^23.1.0",
        "node-emoji": "^2.2.0",
        "posthog-js": "^1.372.6",
        "posthog-node": "^5.33.0",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-markdown": "^10.1.0",
